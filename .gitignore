node_modules/
dist/
build/
.next/
coverage/
*.log
.DS_Store
.env
.env.*
!.env.example
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json
.idea/
*.tsbuildinfo
# Playwright e2e artefacts (reports, traces, results — regenerated per run).
test-results/
playwright-report/
blob-report/
.playwright/
.turbo/
.cache/
.claude/*
# Shared, version-controlled skills (everything else under .claude/ stays local).
!.claude/skills/
# Harness-helper temp files (logs, scripts, extracts) used in this dev box.
# Anything starting with _ at the repo root or any subdir is ignored.
_*
# But drizzle-kit's _journal.json is required state — override the rule:
!**/meta/_journal.json
# TanStack Router conventions: pathless layout routes are prefixed with `_`
# (e.g. `_authenticated.tsx`) and the root is `__root.tsx`. Override the `_*`
# rule for any underscore-prefixed source file under apps/web/src so route
# files stay tracked.
!apps/web/src/**/_*.ts
!apps/web/src/**/_*.tsx
legacy/Innovic_ERP_Migration_Proposal.extracted.txt
# Screenshots / images dropped at the repo root (ad-hoc debugging artefacts).
# Root-anchored so apps/web/public/, legacy/, etc. remain trackable.
/*.jpg
/*.jpeg
/*.png
/*.gif
/*.webp
# Firebase Admin SDK service-account keys (NEVER commit — private credentials).
# Covers Google's default name (`<project>-firebase-adminsdk-<id>-<rand>.json`)
# and any sensibly-renamed `firebase-service-account*.json`.
firebase-service-account*.json
*-firebase-adminsdk-*.json
# Migration export dumps (large generated JSON; regenerated from Firestore).
migration/export/
# Transform outputs (regenerated from export + transform logic; gitignored
# because contents are deterministic from inputs and shouldn't churn diffs).
migration/transform/
# Load outputs (audit JSON of a one-time load, contains user emails / UUIDs).
migration/load-output/
