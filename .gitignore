# Harness-helper temp files (logs, scripts, extracts) used in this dev box.
# Anything starting with _ at the repo root or any subdir is ignored.
_*
# But drizzle-kit's _journal.json is required state — override the rule:
!**/meta/_journal.json
# TanStack Router conventions: pathless layout routes are prefixed with `_`
# (e.g. `_authenticated.tsx`) and the root is `__root.tsx`. Override the `_*`
# rule for any underscore-prefixed source file under apps/web/src so route
# files stay tracked.
!apps/web/src/**/_*.ts
!apps/web/src/**/_*.tsx
legacy/Innovic_ERP_Migration_Proposal.extracted.txt
# Screenshots / images dropped at the repo root (ad-hoc debugging artefacts).
# Root-anchored so apps/web/public/, legacy/, etc. remain trackable.
/*.jpg
/*.jpeg
/*.png
/*.gif
/*.webp
