# Copy to .env.local (dev) or set in Railway/Hetzner env (prod).
# Real secrets NEVER committed. See CLAUDE.md §6 rule 10.

# --- API ---
API_PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Comma-separated list of CORS-allowed origins. REQUIRED in production
# (the API refuses to start without it). In dev/test an empty value falls
# back to permissive `origin: true` with a warning. Example for prod:
#   ALLOWED_ORIGINS=https://erp.innovic.in,https://erp-staging.innovic.in
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Database (Supabase Postgres, ap-south-1) ---
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
DATABASE_URL_POOLED=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:6543/postgres

# --- Supabase (Auth + Storage + Realtime) ---
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=change_me

# --- Frontend (Vite — only VITE_ vars are exposed to browser) ---
VITE_API_URL=http://localhost:3000
VITE_SUPABASE_URL=https://PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# --- Observability ---
# SENTRY_DSN: API process. Empty = Sentry disabled (no init, no requests).
# VITE_SENTRY_DSN: must use the VITE_ prefix or it won't reach the browser.
# Both are no-ops when unset; safe to leave empty until accounts are provisioned.
SENTRY_DSN=
VITE_SENTRY_DSN=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=system@example.com

# --- Backups (Backblaze B2) ---
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=innovic-backups

# --- Firebase migration source (Phase 2 only — T-013 export script) ---
# The legacy ERP runs on Firebase project innovic-erp-v1-77a19. To export,
# generate a service account key in Firebase Console → Project Settings →
# Service accounts → Generate new private key. Save it OUTSIDE the repo OR
# at the repo root (gitignore covers `*-firebase-adminsdk-*.json`). Then:
FIREBASE_PROJECT_ID=innovic-erp-v1-77a19
FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/firebase-service-account.json
