{
  "name": "@innovic/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "dotenv -e ../../.env.local -- tsx src/server.ts",
    "dev:watch": "dotenv -e ../../.env.local -- tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:production": "tsx src/server.ts",
    "test": "dotenv -e ../../.env.local -- vitest run",
    "test:watch": "dotenv -e ../../.env.local -- vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "db:generate": "dotenv -e ../../.env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e ../../.env.local -- drizzle-kit migrate",
    "db:push": "dotenv -e ../../.env.local -- drizzle-kit push",
    "db:studio": "dotenv -e ../../.env.local -- drizzle-kit studio",
    "seed": "dotenv -e ../../.env.local -- tsx src/db/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/sensible": "^6.0.1",
    "@innovic/shared": "workspace:*",
    "@sentry/node": "^10.52.0",
    "@supabase/supabase-js": "^2.46.1",
    "bullmq": "^5.34.0",
    "drizzle-orm": "^0.36.4",
    "exceljs": "^4.4.0",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.2",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "resend": "^4.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.3",
    "@types/supertest": "^6.0.2",
    "dotenv-cli": "^7.4.2",
    "drizzle-kit": "^0.28.1",
    "pino-pretty": "^11.3.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.6"
  }
}
