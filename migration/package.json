{
  "name": "@innovic/migration",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "export": "dotenv -e ../.env.local -- tsx export-firestore.ts",
    "transform": "tsx transform.ts",
    "load": "dotenv -e ../.env.local -- tsx load.ts",
    "validate:phase2": "dotenv -e ../.env.local -- tsx validate-phase2.ts",
    "validate:phase3": "dotenv -e ../.env.local -- tsx validate-phase3.ts",
    "validate:phase4": "dotenv -e ../.env.local -- tsx validate-phase4.ts",
    "validate:phase5": "dotenv -e ../.env.local -- tsx validate-phase5.ts",
    "reconcile": "dotenv -e ../.env.local -- tsx reconcile-op-log.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@innovic/shared": "workspace:*",
    "@supabase/supabase-js": "^2.46.1",
    "drizzle-orm": "^0.36.4",
    "firebase-admin": "^12.6.0",
    "postgres": "^3.4.5",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.3",
    "@types/uuid": "^10.0.0",
    "dotenv-cli": "^7.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.6"
  }
}
